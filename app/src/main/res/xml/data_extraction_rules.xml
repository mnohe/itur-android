<data-extraction-rules>
    <!--
        Allowlist approach: only the paths listed below are backed up.
        Everything else — including Firebase auth shared preferences,
        which contain device-specific tokens — is excluded implicitly.
    -->
    <cloud-backup>
        <!-- User email preference (DataStore proto file). -->
        <include domain="file" path="datastore/user_settings.pb"/>
    </cloud-backup>
    <device-transfer>
        <!-- User email preference (DataStore proto file). -->
        <include domain="file" path="datastore/user_settings.pb"/>
    </device-transfer>
</data-extraction-rules>